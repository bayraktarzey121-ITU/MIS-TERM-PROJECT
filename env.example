import React, { useState } from 'react';
import { useTranslation } from 'react-i18next';
import { Search, Loader2, Dog, Calendar, MapPin, ShieldCheck, Heart } from 'lucide-react';
import { Animal } from '../../types';

export default function AnimalSearch() {
  const { t } = useTranslation();
  const [query, setQuery] = useState('');
  const [loading, setLoading] = useState(false);
  const [result, setResult] = useState<Animal | null>(null);

  const handleSearch = (e: React.FormEvent) => {
    e.preventDefault();
    if (!query) return;
    
    setLoading(true);
    // Simulate lookup
    setTimeout(() => {
      setResult({
        animal_id: 101,
        microchip_id: query,
        name: 'Duman',
        species: 'Dog',
        breed: 'Golden Retriever',
        age_estimate: 24,
        sex: 'M',
        sterilization_status: true,
        status: 'InShelter',
        entry_date: '2025-01-10',
        municipality_id: 1,
      });
      setLoading(false);
    }, 800);
  };

  return (
    <div className="animate-fade-in max-w-4xl mx-auto space-y-8">
      <div className="text-center space-y-2">
        <h2 className="text-3xl font-bold tracking-tight text-gray-900">Mikroçip Sorgulama</h2>
        <p className="text-gray-500">15 haneli mikroçip ID'si ile hayvanın tüm geçmişine ulaşın.</p>
      </div>

      <div className="rounded-2xl bg-white p-2 shadow-xl border border-gray-100 ring-4 ring-blue-50">
        <form onSubmit={handleSearch} className="flex items-center">
          <div className="relative flex-1">
            <Search className="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-400" />
            <input 
              type="text"
              value={query}
              onChange={(e) => setQuery(e.target.value)}
              placeholder="900012345678901"
              maxLength={15}
              className="w-full bg-transparent py-4 pl-12 pr-4 text-lg font-medium outline-none focus:placeholder-transparent"
            />
          </div>
          <button 
            type="submit"
            disabled={loading || query.length < 5}
            className="rounded-xl bg-blue-600 px-8 py-3.5 text-sm font-bold text-white hover:bg-blue-700 disabled:opacity-50 transition-all flex items-center space-x-2"
          >
            {loading ? <Loader2 className="h-4 w-4 animate-spin" /> : <span>Sorgula</span>}
          </button>
        </form>
      </div>

      {result && (
        <div className="animate-fade-in divide-y divide-gray-100 rounded-2xl border border-gray-100 bg-white shadow-lg overflow-hidden">
          <div className="p-8 bg-blue-50/50 flex items-start justify-between">
            <div className="flex space-x-6">
              <div className="h-24 w-24 rounded-2xl bg-white border-2 border-blue-100 flex items-center justify-center">
                <Dog className="h-12 w-12 text-blue-600" />
              </div>
              <div>
                <h3 className="text-2xl font-bold text-gray-900">{result.name}</h3>
                <p className="text-blue-600 font-mono font-bold tracking-widest">{result.microchip_id}</p>
                <div className="mt-3 flex space-x-2">
                  <span className="inline-flex rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-bold text-blue-700">
                    {result.breed}
                  </span>
                  <span className={`inline-flex rounded-full px-2.5 py-0.5 text-xs font-bold ${
                    result.sterilization_status ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700'
                  }`}>
                    {result.sterilization_status ? 'Kısırlaştırılmış' : 'Kısırlaştırılmamış'}
                  </span>
                </div>
              </div>
            </div>
            <div className="text-right">
              <span className="inline-flex rounded-full bg-white border border-gray-200 px-3 py-1 text-sm font-bold text-gray-700 shadow-sm capitalize">
                {result.status}
              </span>
            </div>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-8 p-8">
            <div className="space-y-6">
              <h4 className="text-sm font-bold uppercase tracking-wider text-gray-500">Temel Bilgiler</h4>
              <div className="space-y-4">
                <div className="flex items-center space-x-3">
                  <Dog className="h-4 w-4 text-gray-400" />
                  <span className="text-sm text-gray-600 w-24">Tür:</span>
                  <span className="text-sm font-bold">{result.species}</span>
                </div>
                <div className="flex items-center space-x-3">
                  <Calendar className="h-4 w-4 text-gray-400" />
                  <span className="text-sm text-gray-600 w-24">Yaş:</span>
                  <span className="text-sm font-bold">{Math.floor(result.age_estimate! / 12)} Yaş {result.age_estimate! % 12} Aylık</span>
                </div>
                <div className="flex items-center space-x-3">
                  <MapPin className="h-4 w-4 text-gray-400" />
                  <span className="text-sm text-gray-600 w-24">Belediye:</span>
                  <span className="text-sm font-bold">İstanbul Beşiktaş</span>
                </div>
              </div>
            </div>

            <div className="space-y-6">
              <h4 className="text-sm font-bold uppercase tracking-wider text-gray-500">Son İşlemler</h4>
              <div className="relative space-y-4 before:absolute before:left-2 before:top-2 before:h-full before:w-0.5 before:bg-gray-100">
                <div className="relative pl-6">
                  <div className="absolute left-0 top-1 h-4 w-4 rounded-full border-2 border-white bg-green-500 shadow-sm"></div>
                  <p className="text-xs font-bold text-gray-400 uppercase">10 ŞUBAT 2025</p>
                  <p className="text-sm font-bold text-gray-900">Kuduz Aşısı Uygulandı</p>
                  <p className="text-xs text-gray-500">Beşiktaş Barınağı - Vet. Dr. Ahmet Y.</p>
                </div>
                <div className="relative pl-6">
                  <div className="absolute left-0 top-1 h-4 w-4 rounded-full border-2 border-white bg-blue-500 shadow-sm"></div>
                  <p className="text-xs font-bold text-gray-400 uppercase">15 OCAK 2025</p>
                  <p className="text-sm font-bold text-gray-900">Kısırlaştırma (CNVR)</p>
                  <p className="text-xs text-gray-500">Beşiktaş Barınağı</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
